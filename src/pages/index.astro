---
import fs from 'node:fs';
import path from 'node:path';
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const allNews = (await getCollection('news')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const allTags = [...new Set(allNews.flatMap((news) => news.data.tags))].sort();
const totalNewsCount = allNews.length;

const summaryPath = path.resolve(process.cwd(), 'src/content/summary.md');
const summaryUpdatedAt = fs.statSync(summaryPath).mtime;

const formatDate = (date: Date) => {
	return date.toLocaleDateString('en-US', {
		year: 'numeric',
		month: 'short',
		day: 'numeric',
	}).toUpperCase();
};

const formatSourceDomain = (sourceUrl: string) => {
	return new URL(sourceUrl).hostname.replace(/^www\./, '');
};

const summarySignals = [
	'AI coding tools are becoming orchestration systems, not just autocomplete layers.',
	'Safety, permissions, and trust are now product features, not compliance afterthoughts.',
	'Buyers increasingly want measurable workflow impact instead of flashy demos.',
];

const summaryThemes = [
	{
		title: 'Assistant → Agent',
		body: 'The market is shifting from “help me write code” toward tools that can supervise, execute, and coordinate engineering work.',
	},
	{
		title: 'Trust as a feature',
		body: 'Permission systems, grounded execution, and controlled autonomy are becoming core differentiators.',
	},
	{
		title: 'Enterprise reality',
		body: 'Evaluation is moving toward governance, workflow fit, and provable productivity gains.',
	},
	{
		title: 'Beyond code generation',
		body: 'Triage, CI/CD, execution control, and engineering ops are now part of the AI tooling story.',
	},
];

---

<Layout title="SWE AI Dev News">
	<Fragment slot="header-extra">
		<div class="flex flex-wrap items-center gap-3 lg:justify-end">
			<div class="inline-flex items-center gap-2 rounded-md border border-neutral-800 bg-neutral-900/70 px-3 py-2 text-xs font-mono text-neutral-300 shadow-sm">
				<span class="inline-flex h-7 min-w-7 items-center justify-center rounded-md border border-blue-500/20 bg-blue-500/10 px-2 text-blue-400">{totalNewsCount}</span>
				<span>news items</span>
			</div>
			<div class="hidden md:inline-flex items-center rounded-md border border-neutral-800 bg-neutral-900/70 px-3 py-2 text-xs font-mono text-neutral-500 shadow-sm">
				Updated {summaryUpdatedAt.toLocaleString('en-US', { dateStyle: 'medium', timeStyle: 'short' })}
			</div>
			<button id="open-summary-btn" class="inline-flex items-center rounded-md border border-blue-500/30 bg-blue-500/10 px-3 py-2 text-xs font-mono text-blue-400 shadow-sm transition-all hover:bg-blue-500/20">
				Show AI Summary
			</button>
		</div>
	</Fragment>

	<div id="summary-modal" class="fixed inset-0 z-50 hidden" aria-hidden="true">
		<div id="summary-backdrop" class="absolute inset-0 bg-black/75 backdrop-blur-md opacity-0 transition-opacity duration-300"></div>
		<div class="relative min-h-screen flex items-center justify-center p-4 md:p-8">
			<section id="summary-dialog" class="w-full max-w-7xl rounded-3xl border border-neutral-800/80 bg-gradient-to-b from-neutral-950 via-neutral-950 to-neutral-900 shadow-2xl shadow-black/70 opacity-0 scale-95 translate-y-4 transition-all duration-300">
				<div class="rounded-t-3xl border-b border-neutral-800/70 bg-neutral-950/90 px-5 py-4 md:px-6 md:py-5">
					<div class="flex items-start justify-between gap-4">
						<div class="flex-1 pr-4">
							<div class="mb-3 inline-flex items-center rounded-full border border-blue-500/20 bg-blue-500/10 px-3 py-1 text-[11px] font-mono uppercase tracking-[0.18em] text-blue-400">
								AI Summary
							</div>
							<p class="text-lg leading-7 text-neutral-200 md:text-xl md:leading-8">
								The center of gravity is shifting from <span class="text-white font-semibold">AI that helps write code</span> to <span class="text-white font-semibold">AI that helps supervise, execute, and coordinate software work safely</span>.
							</p>
						</div>
						<button id="close-summary-btn" class="shrink-0 rounded-xl border border-neutral-700 bg-neutral-900/80 px-4 py-2 text-xs font-mono text-neutral-300 transition-colors hover:bg-neutral-800 hover:text-white">
							Close
						</button>
					</div>
					<div class="mt-4 flex flex-wrap items-center gap-3 text-xs font-mono text-neutral-500">
						<span class="rounded-full border border-neutral-800 bg-neutral-900/70 px-3 py-1">Updated {summaryUpdatedAt.toLocaleString('en-US', { dateStyle: 'medium', timeStyle: 'short' })}</span>
						<span class="rounded-full border border-neutral-800 bg-neutral-900/70 px-3 py-1">3 key signals</span>
						<span class="rounded-full border border-neutral-800 bg-neutral-900/70 px-3 py-1">4 market themes</span>
					</div>
				</div>
				<div class="px-5 py-5 md:px-6 md:py-6 flex flex-col gap-4">
					<div class="rounded-2xl border border-neutral-800/70 bg-black/25 p-4 md:p-5">
						<div class="mb-3 text-[11px] font-mono uppercase tracking-[0.18em] text-blue-400">Executive takeaway</div>
						<p class="text-base leading-7 text-neutral-200 md:text-lg md:leading-8">
							AI in SWE is increasingly about <span class="font-semibold text-white">trusted execution</span>, <span class="font-semibold text-white">workflow coordination</span>, and <span class="font-semibold text-white">measurable productivity</span> — not just faster code generation.
						</p>
					</div>
					
					<div class="grid gap-4 lg:grid-cols-[1fr_1.5fr]">
						<div class="rounded-2xl border border-neutral-800/70 bg-black/25 p-4 md:p-5">
							<div class="mb-3 text-[11px] font-mono uppercase tracking-[0.18em] text-blue-400">What stands out now</div>
							<ul class="space-y-2 md:space-y-3">
								{summarySignals.map((signal) => (
									<li class="flex gap-3 text-sm leading-6 text-neutral-300 md:text-base">
										<span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-blue-400"></span>
										<span>{signal}</span>
									</li>
								))}
							</ul>
						</div>
						<div class="rounded-2xl border border-neutral-800/70 bg-black/25 p-4 md:p-5">
							<div class="mb-3 text-[11px] font-mono uppercase tracking-[0.18em] text-blue-400">Current themes</div>
							<div class="grid gap-3 sm:grid-cols-2">
								{summaryThemes.map((theme) => (
									<div class="rounded-xl border border-neutral-800 bg-neutral-950/80 p-3 md:p-4">
										<h3 class="text-xs md:text-sm font-semibold text-white">{theme.title}</h3>
										<p class="mt-1.5 text-xs md:text-sm leading-5 md:leading-6 text-neutral-400">{theme.body}</p>
									</div>
								))}
							</div>
						</div>
					</div>

				</div>
			</section>
		</div>
	</div>
	
	<section class="mb-10">
		<details id="topic-filter" class="group overflow-hidden rounded-2xl border border-neutral-800/70 bg-neutral-900/40 shadow-sm">
			<summary class="flex cursor-pointer list-none flex-col gap-4 px-4 py-4 text-left marker:hidden sm:px-5 md:flex-row md:items-start md:justify-between">
				<div class="flex items-start gap-3">
					<div class="mt-0.5 rounded-xl border border-neutral-800 bg-neutral-950/80 p-2 text-neutral-500 transition-colors group-open:border-blue-500/30 group-open:bg-blue-500/10 group-open:text-blue-400">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" /></svg>
					</div>
					<div>
						<p class="text-sm font-medium text-neutral-200">Topic filters</p>
						<p class="mt-1 text-xs font-mono text-neutral-500">Pick up to 3 topics to narrow the stream. The filter closes after each selection so the news stays in view.</p>
						<div id="topic-filter-selected" class="mt-3 hidden flex-wrap gap-2" aria-live="polite"></div>
					</div>
				</div>
				<div class="flex flex-wrap items-center gap-2 md:justify-end">
					<span id="topic-filter-count" class="rounded-full border border-neutral-800 bg-neutral-950/80 px-3 py-1 text-[11px] font-mono uppercase tracking-[0.18em] text-neutral-400">0/3 selected</span>
					<span class="inline-flex items-center gap-2 self-start rounded-md border border-neutral-800 bg-neutral-950/80 px-3 py-2 text-xs font-mono text-neutral-300 transition-colors group-open:border-blue-500/30 group-open:bg-blue-500/10 group-open:text-blue-400 sm:self-auto">
						<span id="topic-filter-summary-label">Show topics</span>
						<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform duration-200 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
						</svg>
					</span>
				</div>
			</summary>
			<div id="topic-filter-panel" class="border-t border-neutral-800/70 px-4 py-4 sm:px-5">
				<div class="flex flex-col gap-4">
					<div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
						<p class="text-xs font-mono text-neutral-500">Select up to three topics. Stories matching any selected topic will stay visible.</p>
						<button type="button" id="clear-filter-btn" class="hidden w-full sm:w-auto text-xs font-mono text-orange-400 hover:text-orange-300 flex items-center justify-center gap-1.5 transition-colors border border-orange-500/30 bg-orange-500/10 px-2.5 py-1.5 rounded-md shadow-sm disabled:cursor-not-allowed disabled:opacity-50">
							<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" /></svg>
							Clear filters
						</button>
					</div>
					<div class="flex flex-wrap gap-2" role="group" aria-label="Topic filters">
						<button type="button" class="px-3 py-1.5 text-xs font-mono rounded-md border border-neutral-800 bg-neutral-900 text-neutral-400 hover:bg-neutral-800 hover:text-white transition-all shadow-sm" data-filter="all">All Topics</button>
						{allTags.map((tag) => (
							<button type="button" class="px-3 py-1.5 text-xs font-mono rounded-md border border-neutral-800 bg-neutral-900 text-neutral-400 hover:bg-neutral-800 hover:text-white transition-all shadow-sm disabled:cursor-not-allowed disabled:opacity-45" data-tag-button={tag} aria-pressed="false">
								{tag}
							</button>
						))}
					</div>
				</div>
			</div>
		</details>
	</section>

	<section>
		<div class="space-y-6">
			{allNews.map((news) => (
				<article class="group news-item bg-neutral-900/40 border border-neutral-800/60 rounded-xl p-6 hover:bg-neutral-900 transition-all hover:scale-[1.02] duration-300 hover:border-neutral-700 hover:shadow-lg hover:shadow-black/50 relative overflow-hidden" data-tags={news.data.tags.join(',')}>
					<div class="absolute inset-0 bg-gradient-to-r from-blue-500/0 via-blue-500/0 to-blue-500/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>

					<div class="flex flex-col gap-4">
						<header>
							<div class="flex flex-wrap items-center gap-x-4 gap-y-2 mb-3">
								<time class="text-xs font-mono text-neutral-500 flex items-center gap-1.5">
									<svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
									{formatDate(news.data.pubDate)}
								</time>
								<a
									href={news.data.sourceUrl}
									target="_blank"
									rel="noopener noreferrer"
									class="text-[10px] font-mono tracking-wider px-2 py-0.5 rounded-full bg-orange-500/10 text-orange-400 hover:bg-orange-500/20 transition-colors border border-orange-500/20"
								>
									{formatSourceDomain(news.data.sourceUrl)}
								</a>
								<div class="flex flex-wrap gap-1.5">
									{news.data.tags.map(tag => (
										<a href={`${import.meta.env.BASE_URL}?tags=${encodeURIComponent(tag)}`} class="text-[10px] font-mono tracking-wider px-2 py-0.5 rounded-full bg-blue-500/10 text-blue-400 hover:bg-blue-500/20 transition-colors border border-blue-500/20">
											{tag}
										</a>
									))}
								</div>
							</div>

							<h3 class="text-xl md:text-2xl font-bold leading-tight">
								<a href={news.data.sourceUrl} target="_blank" rel="noopener noreferrer" class="text-white hover:text-blue-400 transition-colors flex items-center gap-2 group/link">
									<span>{news.data.title}</span>
									<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 opacity-0 -ml-4 group-hover/link:opacity-100 group-hover/link:ml-0 transition-all text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
								</a>
							</h3>
						</header>

						<p class="text-neutral-400 leading-relaxed text-sm md:text-base">
							{news.data.summary}
						</p>
					</div>
				</article>
			))}

			{allNews.length === 0 && (
				<div class="text-center py-24 bg-neutral-900/30 rounded-xl border border-neutral-800 border-dashed">
					<svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 md:w-16 md:h-16 text-neutral-600 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9.5a2 2 0 00-.586-1.414l-4.5-4.5A2 2 0 0012.586 3H12" /></svg>
					<h3 class="text-xl font-medium text-neutral-300 mb-2">No intelligence found.</h3>
					<p class="text-neutral-500 font-mono text-sm">The collection database is currently empty.</p>
				</div>
			)}
		</div>

		<div id="pagination-controls" class="hidden mt-10 flex flex-col md:flex-row items-center justify-between gap-4 border-t border-neutral-800/60 pt-6"></div>
	</section>

	<script>
		const params = new URLSearchParams(window.location.search);
		const initialPage = parseInt(params.get('page') || '1', 10);
		const ITEMS_PER_PAGE = 20;
		const MAX_SELECTED_TOPICS = 3;

		const normalizeTag = (tag) => tag.toLowerCase().trim();
		const selectedTopicsFromUrl = [
			...params.getAll('tags').flatMap((value) => value.split(',')),
			...((params.get('tag') || '').split(',')),
		]
			.map((tag) => tag.trim())
			.filter(Boolean)
			.filter((tag, index, list) => list.findIndex((entry) => normalizeTag(entry) === normalizeTag(tag)) === index)
			.slice(0, MAX_SELECTED_TOPICS);

		let selectedTopics = selectedTopicsFromUrl;
		let currentPage = initialPage;
		const newsItems = Array.from(document.querySelectorAll('.news-item'));
		let filteredItems = newsItems;
		const clearBtn = document.getElementById('clear-filter-btn');
		const topicFilter = document.getElementById('topic-filter');
		const topicFilterSummaryLabel = document.getElementById('topic-filter-summary-label');
		const topicFilterCount = document.getElementById('topic-filter-count');
		const topicFilterSelected = document.getElementById('topic-filter-selected');
		const topicButtons = Array.from(document.querySelectorAll('[data-tag-button]'));
		const allTopicsButton = document.querySelector('[data-filter="all"]');

		const updateTopicFilterSummary = () => {
			if (!(topicFilter instanceof HTMLDetailsElement) || !topicFilterSummaryLabel) return;
			if (topicFilter.open) {
				topicFilterSummaryLabel.textContent = 'Hide topics';
				return;
			}

			if (!selectedTopics.length) {
				topicFilterSummaryLabel.textContent = 'Show topics';
				return;
			}

			topicFilterSummaryLabel.textContent = selectedTopics.length === 1
				? `1 topic selected`
				: `${selectedTopics.length} topics selected`;
		};

		const summaryModal = document.getElementById('summary-modal');
		const summaryBackdrop = document.getElementById('summary-backdrop');
		const summaryDialog = document.getElementById('summary-dialog');
		const openSummaryBtn = document.getElementById('open-summary-btn');
		const closeSummaryBtn = document.getElementById('close-summary-btn');
		const paginationContainer = document.getElementById('pagination-controls');

		const syncQueryString = (page = 1) => {
			const nextParams = new URLSearchParams();
			if (selectedTopics.length) {
				nextParams.set('tags', selectedTopics.join(','));
			}
			if (page > 1) {
				nextParams.set('page', page.toString());
			}
			const nextUrl = `${window.location.pathname}${nextParams.toString() ? `?${nextParams.toString()}` : ''}`;
			window.history.replaceState({}, '', nextUrl);
		};

		const renderSelectedTopics = () => {
			if (!topicFilterSelected) return;
			if (!selectedTopics.length) {
				topicFilterSelected.innerHTML = '';
				topicFilterSelected.classList.add('hidden');
				return;
			}

			topicFilterSelected.classList.remove('hidden');
			topicFilterSelected.innerHTML = selectedTopics.map((topic) => `
				<span class="inline-flex items-center gap-2 rounded-full border border-blue-500/20 bg-blue-500/10 px-3 py-1 text-[11px] font-mono uppercase tracking-[0.18em] text-blue-400">
					<span>${topic}</span>
				</span>
			`).join('');
		};

		const updateButtonStates = () => {
			const hasSelection = selectedTopics.length > 0;
			if (clearBtn) {
				clearBtn.classList.toggle('hidden', !hasSelection);
				clearBtn.toggleAttribute('disabled', !hasSelection);
			}
			if (topicFilterCount) {
				topicFilterCount.textContent = `${selectedTopics.length}/${MAX_SELECTED_TOPICS} selected`;
				topicFilterCount.classList.toggle('border-blue-500/30', hasSelection);
				topicFilterCount.classList.toggle('bg-blue-500/10', hasSelection);
				topicFilterCount.classList.toggle('text-blue-400', hasSelection);
				topicFilterCount.classList.toggle('border-neutral-800', !hasSelection);
				topicFilterCount.classList.toggle('bg-neutral-950/80', !hasSelection);
				topicFilterCount.classList.toggle('text-neutral-400', !hasSelection);
			}

			topicButtons.forEach((button) => {
				const tag = button.getAttribute('data-tag-button');
				if (!tag) return;
				const isSelected = selectedTopics.some((topic) => normalizeTag(topic) === normalizeTag(tag));
				const limitReached = selectedTopics.length >= MAX_SELECTED_TOPICS;
				button.setAttribute('aria-pressed', String(isSelected));
				button.toggleAttribute('disabled', !isSelected && limitReached);
				button.classList.toggle('bg-blue-500/10', isSelected);
				button.classList.toggle('text-blue-400', isSelected);
				button.classList.toggle('border-blue-500/30', isSelected);
				button.classList.toggle('bg-neutral-900', !isSelected);
				button.classList.toggle('text-neutral-400', !isSelected);
				button.classList.toggle('border-neutral-800', !isSelected);
			});

			if (allTopicsButton) {
				allTopicsButton.classList.toggle('bg-blue-500/10', !hasSelection);
				allTopicsButton.classList.toggle('text-blue-400', !hasSelection);
				allTopicsButton.classList.toggle('border-blue-500/30', !hasSelection);
				allTopicsButton.classList.toggle('bg-neutral-900', hasSelection);
				allTopicsButton.classList.toggle('text-neutral-400', hasSelection);
				allTopicsButton.classList.toggle('border-neutral-800', hasSelection);
			}
		};

		const applyFilters = () => {
			const normalizedSelectedTopics = selectedTopics.map(normalizeTag);
			filteredItems = !normalizedSelectedTopics.length
				? newsItems
				: newsItems.filter((el) => {
					const tagsAttr = el.getAttribute('data-tags');
					if (!tagsAttr) return false;
					const tags = tagsAttr.toLowerCase().split(',').map((value) => value.trim());
					return normalizedSelectedTopics.some((topic) => tags.includes(topic));
				});

			const totalPages = Math.max(1, Math.ceil(filteredItems.length / ITEMS_PER_PAGE));
			const safePage = Math.min(Math.max(currentPage, 1), totalPages);
			currentPage = safePage;
			const startIndex = (safePage - 1) * ITEMS_PER_PAGE;
			const endIndex = startIndex + ITEMS_PER_PAGE;

			newsItems.forEach((el) => {
				el.style.display = 'none';
			});

			filteredItems.forEach((el, index) => {
				el.style.display = index >= startIndex && index < endIndex ? 'block' : 'none';
			});

			syncQueryString(safePage);

			if (paginationContainer) {
				if (filteredItems.length <= ITEMS_PER_PAGE) {
					paginationContainer.innerHTML = '';
					paginationContainer.classList.add('hidden');
					paginationContainer.classList.remove('flex');
					return;
				}

				paginationContainer.classList.remove('hidden');
				paginationContainer.classList.add('flex');

				const prevDisabled = safePage <= 1;
				const nextDisabled = safePage >= totalPages;
				const createUrl = (page) => {
					const nextParams = new URLSearchParams(window.location.search);
					nextParams.set('page', page.toString());
					return `${window.location.pathname}?${nextParams.toString()}`;
				};

				paginationContainer.innerHTML = `
					<div class="text-sm font-mono text-neutral-500 mb-4 md:mb-0">
						Showing ${Math.min(startIndex + 1, filteredItems.length)}-${Math.min(endIndex, filteredItems.length)} of ${filteredItems.length} intelligence logs
					</div>
					<div class="flex items-center gap-2">
						<a href="${prevDisabled ? '#' : createUrl(safePage - 1)}"
						   class="px-3 py-1.5 text-xs font-mono rounded-md border border-neutral-800 ${prevDisabled ? 'opacity-50 cursor-not-allowed bg-neutral-900/50 text-neutral-600' : 'bg-neutral-900 text-neutral-400 hover:bg-neutral-800 hover:text-white'} transition-all shadow-sm">
							Previous
						</a>
						<div class="flex items-center gap-1 mx-2">
							${Array.from({ length: totalPages }, (_, i) => i + 1).map(page => `
								<a href="${createUrl(page)}"
								   class="w-7 h-7 flex items-center justify-center text-xs font-mono rounded-md border ${page === safePage ? 'bg-blue-500/10 border-blue-500/30 text-blue-400' : 'border-neutral-800 bg-neutral-900 text-neutral-400 hover:bg-neutral-800 hover:text-white'} transition-all shadow-sm">
									${page}
								</a>
							`).join('')}
						</div>
						<a href="${nextDisabled ? '#' : createUrl(safePage + 1)}"
						   class="px-3 py-1.5 text-xs font-mono rounded-md border border-neutral-800 ${nextDisabled ? 'opacity-50 cursor-not-allowed bg-neutral-900/50 text-neutral-600' : 'bg-neutral-900 text-neutral-400 hover:bg-neutral-800 hover:text-white'} transition-all shadow-sm">
							Next
						</a>
					</div>
				`;
			}
		};

		const syncFilterUi = () => {
			renderSelectedTopics();
			updateButtonStates();
			updateTopicFilterSummary();
			applyFilters();
		};

		const openSummary = () => {
			if (!summaryModal || !summaryBackdrop || !summaryDialog) return;
			summaryModal.classList.remove('hidden');
			requestAnimationFrame(() => {
				summaryBackdrop.classList.remove('opacity-0');
				summaryDialog.classList.remove('opacity-0', 'scale-95', 'translate-y-4');
			});
			document.body.classList.add('overflow-hidden');
		};

		const closeSummary = () => {
			if (!summaryModal || !summaryBackdrop || !summaryDialog) return;
			summaryBackdrop.classList.add('opacity-0');
			summaryDialog.classList.add('opacity-0', 'scale-95', 'translate-y-4');
			setTimeout(() => {
				summaryModal.classList.add('hidden');
			}, 300);
			document.body.classList.remove('overflow-hidden');
		};

		openSummaryBtn?.addEventListener('click', openSummary);
		closeSummaryBtn?.addEventListener('click', closeSummary);
		summaryBackdrop?.addEventListener('click', closeSummary);
		topicFilter?.addEventListener('toggle', updateTopicFilterSummary);
		document.addEventListener('keydown', (event) => {
			if (event.key === 'Escape') closeSummary();
		});

		clearBtn?.addEventListener('click', () => {
			selectedTopics = [];
			currentPage = 1;
			syncFilterUi();
		});

		allTopicsButton?.addEventListener('click', () => {
			selectedTopics = [];
			currentPage = 1;
			syncFilterUi();
			if (topicFilter instanceof HTMLDetailsElement) {
				topicFilter.open = false;
			}
		});

		topicButtons.forEach((button) => {
			button.addEventListener('click', () => {
				const tag = button.getAttribute('data-tag-button');
				if (!tag) return;
				const existingIndex = selectedTopics.findIndex((topic) => normalizeTag(topic) === normalizeTag(tag));
				if (existingIndex >= 0) {
					selectedTopics = selectedTopics.filter((topic) => normalizeTag(topic) !== normalizeTag(tag));
				} else if (selectedTopics.length < MAX_SELECTED_TOPICS) {
					selectedTopics = [...selectedTopics, tag];
				} else {
					return;
				}

				currentPage = 1;
				syncFilterUi();
				if (topicFilter instanceof HTMLDetailsElement) {
					topicFilter.open = false;
				}
			});
		});

		syncFilterUi();
	</script>
</Layout>
