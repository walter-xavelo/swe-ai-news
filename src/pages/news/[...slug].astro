---
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
	const newsEntries = await getCollection('news');
	return newsEntries.map(entry => ({
		params: { slug: entry.slug }, props: { entry },
	}));
}

interface Props {
	entry: CollectionEntry<'news'>;
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const formatDate = (date: Date) => {
	return date.toLocaleDateString('en-US', {
		year: 'numeric',
		month: 'long',
		day: 'numeric',
	}).toUpperCase();
};
---

<Layout title={`${entry.data.title} - AI Dev News`}>
	<article class="space-y-8">
		<header class="border-b border-dashed border-[#00ff41] pb-6">
			<div class="text-xs opacity-60 mb-2">
				$ cat /news/{entry.slug}.md
			</div>
			<h1 class="text-3xl font-bold mb-4 text-[#00ff41] leading-tight terminal-glow">
				{entry.data.title}
			</h1>
			<div class="flex flex-wrap gap-4 text-xs">
				<div class="flex items-center gap-2">
					<span class="opacity-60">PUBLISHED:</span>
					<span class="font-bold">{formatDate(entry.data.pubDate)}</span>
				</div>
				<div class="flex items-center gap-2">
					<span class="opacity-60">TAGS:</span>
					<span class="font-bold">[{entry.data.tags.join('] [')}]</span>
				</div>
			</div>
		</header>

		<div class="prose prose-invert max-w-none prose-p:text-[#00ff41] prose-headings:text-[#00ff41] prose-strong:text-[#00ff41] prose-code:text-[#00ff41] prose-a:text-[#00ff41]">
			<div class="border-l-2 border-[#00ff41] pl-6 py-2 italic opacity-90 mb-8 bg-[#00ff41]/5">
				<h2 class="text-sm font-bold not-italic mb-2 uppercase tracking-widest opacity-60">Executive Summary:</h2>
				{entry.data.summary}
			</div>
			
			<div class="mt-8 leading-relaxed">
				<Content />
			</div>
		</div>

		<footer class="mt-12 pt-8 border-t border-dashed border-[#00ff41]">
			<div class="flex flex-col sm:flex-row justify-between items-center gap-6">
				<a href={entry.data.sourceUrl} target="_blank" rel="noopener noreferrer" class="bg-[#00ff41] text-[#000000] px-6 py-3 font-bold hover:bg-[#00ff41] hover:shadow-[0_0_15px_#00ff41] transition-all flex items-center gap-2 group">
					[ READ_ORIGINAL_SOURCE ]
					<span class="group-hover:translate-x-1 transition-transform">-></span>
				</a>
				<a href="/" class="text-sm hover:underline opacity-80">
					[ BACK_TO_ROOT ]
				</a>
			</div>
		</footer>
	</article>
</Layout>

<style is:global>
	/* Custom styles for rendered markdown content */
	.prose p {
		margin-bottom: 1.5rem;
	}
	.prose h2, .prose h3 {
		margin-top: 2rem;
		margin-bottom: 1rem;
		font-weight: bold;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
	.prose ul {
		list-style: none;
		padding-left: 0;
	}
	.prose li::before {
		content: ">> ";
		color: #00ff41;
		margin-right: 0.5rem;
	}
	.prose li {
		margin-bottom: 0.5rem;
	}
</style>
