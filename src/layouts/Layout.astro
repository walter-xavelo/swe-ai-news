---
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
	</head>
	<body class="bg-black text-neutral-100 min-h-screen antialiased font-sans">
		<div class="max-w-6xl mx-auto px-6 py-10 md:py-12">
			<header class="mb-8 border-b border-neutral-800/80 pb-8">
				<div class="flex flex-col gap-6 lg:flex-row lg:items-start lg:justify-between">
					<div class="min-w-0">
						<h1 class="text-4xl md:text-5xl font-bold tracking-tight text-white mb-2">SWE AI News</h1>
						<p class="text-sm md:text-base text-neutral-500 font-mono">Curated intelligence for engineers.</p>
					</div>

					<div class="flex flex-col items-start gap-4 lg:items-end">
						<nav class="flex gap-6 text-sm font-medium">
							<a href={import.meta.env.BASE_URL} class="text-neutral-400 hover:text-white transition-colors">Home</a>
							<a href="https://github.com/walter-xavelo/swe-ai-news" target="_blank" rel="noopener noreferrer" class="text-neutral-400 hover:text-white transition-colors">GitHub</a>
							<a href={`${import.meta.env.BASE_URL}about`} class="text-neutral-400 hover:text-white transition-colors">About</a>
						</nav>
						<div class="w-full lg:w-auto">
							<slot name="header-extra" />
						</div>
					</div>
				</div>
			</header>
			<main>
				<slot />
			</main>
		</div>
	</body>
</html>
